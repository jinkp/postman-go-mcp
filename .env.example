# MCP Transport: stdio | sse (default: stdio)
MCP_TRANSPORT=stdio

# HTTP port — only used when MCP_TRANSPORT=sse
MCP_HTTP_PORT=8080

# SQLite database file path
DB_PATH=./data/postman.db

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Dry-run mode: when true, no files are written to disk
DRY_RUN=false
